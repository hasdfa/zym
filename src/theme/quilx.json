{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Quilx",
  "author": "quilx",
  "themes": [
    {
      "name": "quilx",
      "appearance": "dark",
      "style": {
        "background": "#2d2d2d",
        "foreground": "#f1f1f1",
        "border": "#434346",
        "elevated_surface.background": "#383838",
        "element.selected": "#3f4b5b",
        "editor.background": "#2d2d2d",
        "editor.foreground": "#f1f1f1",
        "editor.line_number": "#888888",
        "editor.active_line_number": "#bbc2cf",
        "search.match_background": "#e5a50a26",
        "search.match_background.current": "#e5a50a59",
        "text.muted": "#5b6268",
        "text.accent": "#c678dd",
        "success": "#98be65",
        "warning": "#ecbe7b",
        "error": "#ff6c6b",
        "info": "#51afef",
        "hint": "#4db5bd",
        "syntax": {
          "comment": { "color": "#80878c" },
          "operator": { "color": "#5ab9f9" },
          "punctuation": { "color": "#5ab9f9" },
          "punctuation.special": { "color": "#e69052" },
          "string": { "color": "#a3c970" },
          "string.regex": { "color": "#59c2ca" },
          "string.escape": { "color": "#cf80e6" },
          "number": { "color": "#ff7b7a" },
          "boolean": { "color": "#ff7b7a" },
          "constant.builtin": { "color": "#e69052" },
          "constant": { "color": "#afa7e7" },
          "variable.special": { "color": "#afa7e7" },
          "variable.parameter": { "color": "#62a6bc" },
          "attribute": { "color": "#f4c682" },
          "tag": { "color": "#5ab9f9" },
          "keyword": { "color": "#5ab9f9" },
          "property": { "color": "#cf80e6" },
          "type": { "color": "#f4c682" },
          "constructor": { "color": "#f4c682" },
          "function": { "color": "#f4c682" }
        }
      }
    }
  ]
}
