{
  "$schema": "./theme.schema.json",
  "name": "adwaita",
  "appearance": "dark",
  "ui": {
    "editor": {
      "foreground": "#ffffff",
      "background": "#1d1d20",
      "lineNumber": "rgba(255, 255, 255, 0.55)"
    },
    "text": {
      "muted": "rgba(255, 255, 255, 0.55)",
      "accent": "#81d0ff"
    },
    "border": "rgba(255, 255, 255, 0.15)",
    "search": {
      "match": "#e5a50a26",
      "matchCurrent": "#e5a50a59"
    }
  },
  "syntax": {
    "comment": {
      "color": "#80878c"
    },
    "operator": {
      "color": "#5ab9f9"
    },
    "punctuation": {
      "color": "#5ab9f9"
    },
    "punctuation.special": {
      "color": "#e69052"
    },
    "string": {
      "color": "#a3c970"
    },
    "string.regex": {
      "color": "#59c2ca"
    },
    "string.escape": {
      "color": "#cf80e6"
    },
    "number": {
      "color": "#ff7b7a"
    },
    "boolean": {
      "color": "#ff7b7a"
    },
    "constant.builtin": {
      "color": "#e69052"
    },
    "constant": {
      "color": "#afa7e7"
    },
    "variable.special": {
      "color": "#afa7e7"
    },
    "variable.parameter": {
      "color": "#62a6bc"
    },
    "attribute": {
      "color": "#f4c682"
    },
    "tag": {
      "color": "#5ab9f9"
    },
    "keyword": {
      "color": "#5ab9f9"
    },
    "property": {
      "color": "#cf80e6"
    },
    "type": {
      "color": "#f4c682"
    },
    "constructor": {
      "color": "#f4c682"
    },
    "function": {
      "color": "#f4c682"
    }
  }
}
