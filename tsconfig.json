{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2020"],
    // Typed Node globals (require/process/__filename/...) via @types/node.
    "types": ["node"],

    "allowJs": true,
    "noEmit": true,
    "strict": true,

    // The app runs straight from source via Node's TypeScript type-stripping
    // (`node src/index.ts`), so relative imports keep their `.ts` extension.
    "allowImportingTsExtensions": true,

    // Generated GIR types rely on this (tolerates GObject override conflicts).
    "skipLibCheck": true,

    // Map `require('node-gtk')` to the types generated by `node-gtk gen-types`.
    "paths": {
      "node-gtk": ["./node_modules/.node-gtk-types/node-gtk.d.ts"],
      "zym/plugin-api": ["./src/plugin-api.ts"]
    }
  },
  "include": ["src/**/*", "plugins/**/*", "node_modules/.node-gtk-types/node-gtk.d.ts"]
}
